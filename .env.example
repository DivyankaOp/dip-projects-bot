# Yeh file copy karke naam ".env.local" rakho, aur neeche khaali jagah par apni keys daal do
# Vercel par deploy karte waqt yeh 3 values "Environment Variables" section mein daalni hongi

# Anthropic (Claude) API key - console.anthropic.com se milegi
ANTHROPIC_API_KEY=

# Supabase project URL - Supabase dashboard > Settings > API mein milega
SUPABASE_URL=

# Supabase SERVICE ROLE key (anon key nahi!) - Supabase dashboard > Settings > API mein "service_role" wali key
# Yeh secret hai, kabhi bhi frontend/client code mein expose mat karna
SUPABASE_SERVICE_ROLE_KEY=
